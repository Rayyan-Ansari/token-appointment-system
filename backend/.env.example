# Database
DATABASE_URL="postgresql://username:password@localhost:5432/token_appointment_db?schema=public"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Server
PORT=5000
NODE_ENV="development"

# CORS
FRONTEND_URL="http://localhost:3000"

# File Upload
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=5242880  # 5MB in bytes