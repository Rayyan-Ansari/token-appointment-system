# Database - Get this from Neon (neon.tech) or Supabase (supabase.com) after creating a free PostgreSQL database
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT Secret - Generate a strong random string (e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_STRING"

# Server
PORT=10000
NODE_ENV="production"

# CORS - Set this to your Vercel frontend URL after deployment (e.g. https://your-app.vercel.app)
FRONTEND_URL="https://your-app.vercel.app"

# File Upload
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=5242880
