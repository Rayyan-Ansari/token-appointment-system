// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Admin users
model Admin {
  id           BigInt    @id @default(autoincrement())
  email        String    @unique @db.Citext
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  reviewedApprovals DoctorApproval[]

  @@map("admins")
}

// Patient users
model User {
  id           BigInt    @id @default(autoincrement())
  email        String    @unique @db.Citext
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  phone        String
  dob          DateTime  @db.Date
  sex          Sex
  address      String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  tokens    Token[]
  tokenLogs TokenLog[]

  @@map("users")
}

// Doctor users
model Doctor {
  id                   BigInt    @id @default(autoincrement())
  email                String    @unique @db.Citext
  passwordHash         String    @map("password_hash")
  fullName             String    @map("full_name")
  phone                String
  dob                  DateTime  @db.Date
  sex                  Sex
  qualification        String
  specialization       String
  yearsExperience      Int       @map("years_experience")
  licenseNumber        String    @map("license_number")
  licenseDocumentPath  String?   @map("license_document_path")
  isActive             Boolean   @default(false) @map("is_active")
  workingHoursStart    String?   @map("working_hours_start")
  workingHoursEnd      String?   @map("working_hours_end")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  approvals DoctorApproval[]
  sessions  Session[]
  tokenLogs TokenLog[]

  @@map("doctors")
}

// Doctor approval system
model DoctorApproval {
  id         BigInt            @id @default(autoincrement())
  doctorId   BigInt            @map("doctor_id")
  status     ApprovalStatus
  reviewedBy BigInt?           @map("reviewed_by")
  reviewedAt DateTime?         @map("reviewed_at") @db.Timestamptz(6)
  note       String?
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  reviewer Admin? @relation(fields: [reviewedBy], references: [id])

  @@index([doctorId], map: "doctor_approvals_doctor_idx")
  @@map("doctor_approvals")
}

// Doctor sessions (one per day per doctor)
model Session {
  id             BigInt        @id @default(autoincrement())
  doctorId       BigInt        @map("doctor_id")
  sessionDate    DateTime      @map("session_date") @db.Date
  status         SessionStatus @default(NOT_STARTED)
  currentTokenNo Int           @default(0) @map("current_token_no")
  maxTokenNo     Int           @default(0) @map("max_token_no")
  startedAt      DateTime?     @map("started_at") @db.Timestamptz(6)
  endedAt        DateTime?     @map("ended_at") @db.Timestamptz(6)

  // Relations
  doctor    Doctor     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  tokens    Token[]
  tokenLogs TokenLog[]

  @@unique([doctorId, sessionDate])
  @@index([doctorId, status], map: "sessions_doctor_active_idx")
  @@map("sessions")
}

// Individual tokens
model Token {
  id          BigInt      @id @default(autoincrement())
  sessionId   BigInt      @map("session_id")
  patientId   BigInt      @map("patient_id")
  tokenNo     Int         @map("token_no")
  status      TokenStatus @default(WAITING)
  bookedAt    DateTime    @default(now()) @map("booked_at") @db.Timestamptz(6)
  calledAt    DateTime?   @map("called_at") @db.Timestamptz(6)
  servedAt    DateTime?   @map("served_at") @db.Timestamptz(6)
  canceledAt  DateTime?   @map("canceled_at") @db.Timestamptz(6)
  noShowAt    DateTime?   @map("no_show_at") @db.Timestamptz(6)

  // Relations
  session  Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  patient  User       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tokenLogs TokenLog[]

  @@unique([sessionId, tokenNo])
  @@index([sessionId, status, tokenNo], map: "tokens_session_status_idx")
  @@index([patientId, sessionId], map: "tokens_patient_session_idx")
  @@map("tokens")
}

// Audit log for all token and session actions
model TokenLog {
  id        BigInt      @id @default(autoincrement())
  tokenId   BigInt?     @map("token_id")
  sessionId BigInt?     @map("session_id")
  doctorId  BigInt?     @map("doctor_id")
  patientId BigInt?     @map("patient_id")
  action    LogAction
  meta      Json?       @db.JsonB
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  token   Token?   @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  doctor  Doctor?  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient User?    @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([action, createdAt], map: "token_logs_action_time_idx")
  @@map("token_logs")
}

// Enums
enum Sex {
  M
  F
  O
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SessionStatus {
  NOT_STARTED
  ACTIVE
  PAUSED
  ENDED
}

enum TokenStatus {
  WAITING
  CALLED
  SERVED
  CANCELED
  NO_SHOW
}

enum LogAction {
  BOOKED
  CALLED
  SERVED
  CANCELED
  NO_SHOW
  SESSION_START
  SESSION_PAUSE
  SESSION_RESUME
  SESSION_END
}